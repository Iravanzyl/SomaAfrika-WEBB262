@page "/"
@implements IDisposable
@inject LanguageService Lang
@inject NavigationManager Nav
@rendermode InteractiveServer

<PageTitle>SomaAfrika - @Lang.T("tagline")</PageTitle>

<!-- Hero Section -->
<div class="hero-section py-5 mb-5">
    <div class="container text-center">
        <div class="mb-4">
            <img src="/images/SomaAfrica_WEBB262_SS1_Logo_No.png"
                 alt="SomaAfrika Logo"
                 style="height:120px; width:auto;" />
        </div>
        <h1 class="display-4 fw-bold text-success mb-3">SomaAfrika</h1>
        <p class="lead text-muted mb-4">@Lang.T("tagline")</p>

        <div class="d-flex justify-content-center gap-3 flex-wrap">
            <a href="/listings" class="btn btn-success btn-lg px-4">
                 Browse Textbooks
            </a>
            <a href="/wanted" class="btn btn-outline-success btn-lg px-4">
                 Post a Wanted Ad
            </a>
        </div>
    </div>
</div>

<!-- How It Works -->
<div class="container mb-5">
    <h2 class="text-center fw-bold mb-4">How It Works</h2>
    <div class="row g-4 text-center">
        <div class="col-12 col-md-4">
            <div class="card h-100 border-0 shadow-sm p-3">
                <div class="card-body">
                    <div class="fs-1 mb-3">📖</div>
                    <h5 class="fw-bold">1. List Your Textbook</h5>
                    <p class="text-muted">
                        Post your used textbooks with price, condition and campus location.
                        Reach students at your university instantly.
                    </p>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-4">
            <div class="card h-100 border-0 shadow-sm p-3">
                <div class="card-body">
                    <div class="fs-1 mb-3">🤝</div>
                    <h5 class="fw-bold">2. Make an Offer</h5>
                    <p class="text-muted">
                        Found a book you need? Make an offer directly to the seller
                        and negotiate a fair price.
                    </p>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-4">
            <div class="card h-100 border-0 shadow-sm p-3">
                <div class="card-body">
                    <div class="fs-1 mb-3">💵</div>
                    <h5 class="fw-bold">3. @Lang.T("cash_on_meetup")</h5>
                    <p class="text-muted">
                        Meet safely on campus and pay cash on meetup.
                        Simple, safe and no online payment needed.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Africanisation — Community Trust Section -->
<div class="bg-success text-white py-5 mb-5">
    <div class="container text-center">
        <h2 class="fw-bold mb-3">⭐ @Lang.T("trust_score")</h2>
        <p class="lead mb-4">
            Every user earns a Community Trust Score based on completed
            transactions and reviews from other students.
            The higher your score, the more trusted you are on campus.
        </p>
        <div class="row justify-content-center g-3">
            <div class="col-6 col-md-3">
                <div class="card bg-white text-success text-center p-3">
                    <div class="fs-2 fw-bold">★ 4.8</div>
                    <small class="text-muted">Top Seller</small>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card bg-white text-success text-center p-3">
                    <div class="fs-2 fw-bold">★ 4.5</div>
                    <small class="text-muted">Trusted Buyer</small>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card bg-white text-success text-center p-3">
                    <div class="fs-2 fw-bold">★ 5.0</div>
                    <small class="text-muted">Community Star</small>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Safety Tip -->
<div class="container mb-5">
    <div class="alert alert-warning d-flex align-items-start gap-3">
        <span class="fs-3">⚠️</span>
        <div>
            <strong>@Lang.T("cash_on_meetup") Safety Tip</strong>
            <p class="mb-0 mt-1">@Lang.T("meetup_safety")</p>
        </div>
    </div>
</div>

<!-- Call to Action -->
<div class="container text-center mb-5">
    <h3 class="fw-bold mb-3">Ready to start saving?</h3>
    <p class="text-muted mb-4">
        Join thousands of students buying and selling textbooks on campus.
    </p>
    <AuthorizeView>
        <NotAuthorized>
            <a href="/Account/Register" class="btn btn-success btn-lg px-5">
                Get Started — It's Free
            </a>
        </NotAuthorized>
        <Authorized>
            <a href="/listings/create" class="btn btn-success btn-lg px-5">
                ➕ Post Your First Listing
            </a>
        </Authorized>
    </AuthorizeView>
</div>

@code {
    protected override void OnInitialized()
    {
        Lang.OnLanguageChanged += StateHasChangedHandler;
    }

    private void StateHasChangedHandler()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Lang.OnLanguageChanged -= StateHasChangedHandler;
    }
} 
