@page "/reviews/create/{TransactionId:int}"
@using SomaAfrica.Models
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@attribute [Authorize]
@inject ApplicationDbContext Db
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthStateProvider
@inject LanguageService Lang
@rendermode InteractiveServer

<PageTitle>Leave a Review - SomaShare</PageTitle>

<div class="container py-4" style="max-width:560px;">

    <h2 class="fw-bold mb-2">⭐ Leave a Review</h2>
    <p class="text-muted mb-4">
        Share your experience to help the community make trusted decisions.
    </p>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-success"></div>
        </div>
    }
    else if (alreadyReviewed)
    {
        <div class="alert alert-info">
            <span class="fs-4">✅</span>
            <strong>You have already reviewed this transaction.</strong>
            <p class="mb-0 mt-1">
                <a href="/dashboard">Back to Dashboard</a>
            </p>
        </div>
    }
    else if (transaction == null)
    {
        <div class="alert alert-danger">
            Transaction not found.
            <a href="/dashboard">Back to Dashboard</a>
        </div>
    }
    else
    {
        <!-- Transaction Summary -->
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-light fw-bold">
                Transaction Summary
            </div>
            <div class="card-body">
                <p class="mb-1">
                    <strong>Book:</strong>
                    @transaction.Offer?.Listing?.Textbook?.Title
                </p>
                <p class="mb-1">
                    <strong>Price Paid:</strong>
                    <span class="text-success fw-bold">
                        R @transaction.Offer?.ProposedPrice.ToString("N0")
                    </span>
                </p>
                <p class="mb-0">
                    <strong>Payment:</strong> 💵 Cash on Meetup
                </p>
            </div>
        </div>

        @if (successMsg != null)
        {
            <div class="alert alert-success">
                ✅ @successMsg
                <br />
                <a href="/dashboard" class="btn btn-success mt-2">
                    Back to Dashboard
                </a>
            </div>
        }
        else
        {
            <EditForm Model="formModel" OnValidSubmit="HandleSubmit">
                <DataAnnotationsValidator />
                <ValidationSummary class="alert alert-warning" />

                <div class="card shadow-sm mb-3">
                    <div class="card-header bg-warning fw-bold">
                        ⭐ Your Rating
                    </div>
                    <div class="card-body">

                        <!-- Star Rating Buttons -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">
                                Rating <span class="text-danger">*</span>
                            </label>
                            <div class="d-flex gap-2">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    var star = i;
                                    <button type="button"
                                            class="btn @(formModel.Rating >= star
                                                                                                                                    ? "btn-warning"
                                                                                                                                    : "btn-outline-warning") fs-4"
                                    @onclick="() => formModel.Rating = star">
                                ★
                            </button>
                        }
                    </div>
                    <div class="mt-1 text-muted small">
                        @RatingLabel(formModel.Rating)
                    </div>
                    <ValidationMessage For="() => formModel.Rating"
                                       class="text-danger small" />
                </div>

                <!-- Comment -->
                <div class="mb-3">
                    <label class="form-label fw-semibold">
                        Comment
                        <span class="text-muted small">(optional)</span>
                    </label>
                    <InputTextArea class="form-control"
                                   @bind-Value="formModel.Comment"
                                   rows="4"
                                   placeholder="Share your experience with this transaction..." />
                </div>

            </div>
        </div>

        <!-- Community Trust Reminder -->
        <div class="alert alert-success mb-3">
            ⭐ <strong>@Lang.T("trust_score")</strong> —
            Your review helps build community trust on campus.
            Be honest and fair.
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-warning fw-bold"
                    disabled="@saving">
                @(saving ? "Submitting..." : "Submit Review")
            </button>
            <a href="/dashboard" class="btn btn-outline-secondary">
                @Lang.T("cancel")
            </a>
        </div>

    </EditForm>
}
    }
</div>

@code {
    [Parameter] public int TransactionId { get; set; }

    private Transaction? transaction;
    private string? currentUserId;
    private string? reviewedUserId;
    private string? successMsg;
    private string? errorMsg = null;
    private bool isLoading = true;
    private bool alreadyReviewed;
    private bool saving;

    private ReviewFormModel formModel = new();

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        currentUserId = auth.User.FindFirst(
            System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        transaction = await Db.Transactions
            .Include(t => t.Offer)
                .ThenInclude(o => o.Listing)
                    .ThenInclude(l => l.Textbook)
            .FirstOrDefaultAsync(t => t.TransactionId == TransactionId);

        if (transaction != null)
        {
            // Work out who is being reviewed
            // If current user is buyer they review the seller and vice versa
            reviewedUserId = transaction.BuyerId == currentUserId
                ? transaction.SellerId
                : transaction.BuyerId;

            // Check if this user already left a review for this transaction
            alreadyReviewed = await Db.Reviews.AnyAsync(r =>
                r.TransactionId == TransactionId &&
                r.ReviewerId == currentUserId);
        }

        isLoading = false;
    }

    private async Task HandleSubmit()
    {
        saving = true;
        errorMsg = null;

        try
        {
            var review = new Review
            {
                TransactionId = TransactionId,
                ReviewerId = currentUserId!,
                ReviewedUserId = reviewedUserId!,
                Rating = formModel.Rating,
                Comment = formModel.Comment ?? ""
            };

            Db.Reviews.Add(review);

            // Update the reviewed user's TrustScore on their profile
            var reviewedUser = await Db.Users
                .FirstOrDefaultAsync(u => u.Id == reviewedUserId);

            if (reviewedUser != null)
            {
                var allRatings = await Db.Reviews
                    .Where(r => r.ReviewedUserId == reviewedUserId)
                    .Select(r => r.Rating)
                    .ToListAsync();

                allRatings.Add(formModel.Rating);
                reviewedUser.TrustScore = (decimal)allRatings.Average();
            }

            await Db.SaveChangesAsync();
            successMsg = "Your review has been submitted. Thank you!";
        }
        catch (Exception)
        {
            errorMsg = "Failed to submit review. Please try again.";
        }
        finally
        {
            saving = false;
        }
    }

    private string RatingLabel(int rating) => rating switch
    {
        1 => "⭐ Poor — not recommended",
        2 => "⭐⭐ Below average",
        3 => "⭐⭐⭐ Average — okay experience",
        4 => "⭐⭐⭐⭐ Good — would transact again",
        5 => "⭐⭐⭐⭐⭐ Excellent — highly recommended!",
        _ => "Click a star to rate"
    };

    public class ReviewFormModel
    {
        [System.ComponentModel.DataAnnotations.Range(
            1, 5, ErrorMessage = "Please select a star rating")]
        public int Rating { get; set; }

        public string? Comment { get; set; }
    }
} 
